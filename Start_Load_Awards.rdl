  <DataSets>
    <DataSet Name="Load_Control">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@award_load_user">
            <Value>=Parameters!award_load_user.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@award_source_file_name">
            <Value>=Parameters!award_source_file_name.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@award_source_path">
            <Value>=Parameters!award_source_path.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--declare 
--	@award_source_file_name varchar(50),
--	@award_source_path varchar(200),
--	@award_load_user varchar(20)

select
	@award_load_user as 'Award_Bill_Load_User',
	@award_source_file_name as 'Award_Bill_Source_File',
	@award_source_path as 'Award_Bill_Source_Path',
	--@award_source_path + '/' + @award_source_file_name as 'Award_Src_Full_Path',
	convert(varchar, getdate(), 120) as 'Award_Bill_load_date'
;
update MSUF.CNTL_INFO
	set CNTL_INFO =isnull(@award_load_user, '')
	where CNTL_KEY = 'Award_Load_User'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = isnull(@award_source_file_name, '')
	where CNTL_KEY = 'Award_Source_File'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = isnull(@award_source_path, '')
	where CNTL_KEY = 'Award_Source_Path'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = convert(varchar, getdate(), 120) 
	where CNTL_KEY = 'Award_Load_Date'</CommandText>
      </Query>
      <Fields>
        <Field Name="Award_Bill_Load_User">
          <DataField>Award_Bill_Load_User</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Award_Bill_Source_File">
          <DataField>Award_Bill_Source_File</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Award_Bill_Source_Path">
          <DataField>Award_Bill_Source_Path</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Award_Bill_load_date">
          <DataField>Award_Bill_load_date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Exec_Prog">
      <Query>
        <DataSourceName>MSDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@job_name">
            <Value>=Parameters!job_name.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>waitfor delay '00:00:10';

EXEC msdb.dbo.sp_start_job 'RunSSIS_LoadAwardTbl';

waitfor delay '00:00:30';

EXEC msdb.dbo.sp_help_jobactivity @job_name = 'RunSSIS_LoadAwardTbl';</CommandText>
      </Query>
