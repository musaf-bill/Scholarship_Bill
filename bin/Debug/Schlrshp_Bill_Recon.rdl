    <DataSet Name="Journal_entry">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <CommandText>/*
PURPOSE:		Provide import ready file of GL Journal Entries based on scholarship bill
*/

DECLARE @refText NVARCHAR(50),
		@postDate NVARCHAR(12)
SET @refText = (SELECT LEFT(CNTL_INFO,LEN(CNTL_INFO)-5) FROM [msuf].[CNTL_INFO] WHERE CNTL_KEY = 'Schlr_Bill_Source_File');
SET @postDate = 'Add Date';

WITH Funds AS (
	SELECT --Total awards for each scholarship billed by MSU 
		w.FundCode AS Fund,
		w.FAIndexCode,
		SUM(w.ScholAmtPd) AS Amount
	FROM MSUF.SCHLR_AWARD_WORK AS w
	GROUP BY 
		w.FundCode, 
		w.FAIndexCode
)
, totalTally AS (
	SELECT
	SUM(Amount) AS amount
	FROM funds AS f
)
, Debit_Entry AS (
	SELECT --Total awards for each scholarship billed by MSU 
		f.[FE_Entity_ID] +'-5960-999' AS Account_Number,
		@postDate AS Post_Date,
		'Debit' AS [Type],
		d.Amount,
		@refText AS Journal_Reference,
		'Regular' AS Encumbrance_State,
		d.Fund AS Fund,
		'Temporarily Restricted Net Assets' AS Class,
		'72 - Scholarships' AS [FUNCTION],
		'MSU Index' AS Attribute_Type,
		d.FAIndexCode,
		--'11' AS Entity,
		f.[FE_Entity_ID] AS Entity
		,ROW_NUMBER() OVER (ORDER BY d.Fund) AS NR
	FROM Funds AS d
		LEFT JOIN (SELECT FE_ProjectID, FE_Entity_ID FROM dw.Fund GROUP BY FE_ProjectID, FE_Entity_ID) AS f
			ON f.FE_ProjectID = d.Fund 

)
, Credit_Entry AS (
	SELECT --Total awards for each scholarship billed by MSU 
		f.[FE_Entity_ID] +'-1000-999' AS Account_Number,
		@postDate AS Post_Date,
		'Credit' AS [Type],
		c.Amount,
		@refText AS Journal_Reference,
		'Regular' AS Encumbrance_State,
		c.Fund AS Fund,
		'Temporarily Restricted Net Assets' AS Class,
		'99 - None' AS [FUNCTION],
		'MSU Index' AS Attribute_Type,
		c.FAIndexCode,
		--'11' AS Entity,
		f.[FE_Entity_ID] AS Entity
	,	ROW_NUMBER() OVER (ORDER BY c.Fund) AS NR
	FROM Funds AS c
		LEFT JOIN (SELECT FE_ProjectID, FE_Entity_ID FROM dw.Fund GROUP BY FE_ProjectID, FE_Entity_ID) AS f
			ON f.FE_ProjectID = c.Fund 
)

SELECT * FROM Debit_Entry
UNION
 SELECT * FROM Credit_Entry
UNION 
	SELECT --Total awards for each scholarship billed by MSU 
		'11-5960-999' AS Account_Number,
		@postDate AS Post_Date,
		'Credit' AS [Type],
		t.Amount,
		@refText AS Journal_Reference,
		'Regular' AS Encumbrance_State,
		'91424' as Fund,
		'Temporarily Restricted Net Assets' AS Class,
		'72 - Scholarships' AS [FUNCTION],
		'MSU Index' AS Attribute_Type,
		'422000' AS FAIndexCode,
		'11' AS Entity
		, 9998 AS NR
	FROM totalTally AS t
UNION 
	SELECT --Total awards for each scholarship billed by MSU 
		'11-1000-999' AS Account_Number,
		@postDate AS Post_Date,
		'Debit' AS [Type],
		t.Amount,
		@refText AS Journal_Reference,
		'Regular' AS Encumbrance_State,
		'91424' as Fund,
		'Temporarily Restricted Net Assets' AS Class,
		'99 - None' AS [FUNCTION],
		'MSU Index' AS Attribute_Type,
		'422000' AS FAIndexCode,
		'11' AS Entity
		,9999 AS NR
	FROM totalTally AS t
ORDER BY Fund</CommandText>
      </Query>
      <Fields>
        <Field Name="Account_Number">
          <DataField>Account_Number</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Post_Date">
          <DataField>Post_Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Type">
          <DataField>Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Amount">
          <DataField>Amount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Journal_Reference">
          <DataField>Journal_Reference</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Encumbrance_State">
          <DataField>Encumbrance_State</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Fund">
          <DataField>Fund</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Class">
          <DataField>Class</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FUNCTION">
          <DataField>FUNCTION</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Attribute_Type">
          <DataField>Attribute_Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FAIndexCode">
          <DataField>FAIndexCode</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Entity">
          <DataField>Entity</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NR">
          <DataField>NR</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="MSU_Remit">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <CommandText>/*
PURPOSE:		Provide send ready file of MSU REMIT
*/


with Funds AS (
	select --Total awards for each scholarship billed by MSU 
		w.FAIndexCode,
		SUM(w.ScholAmtPd) as Amount
	from MSUF.SCHLR_AWARD_WORK AS w
	group by 

		w.FAIndexCode
)
, totalTally AS (
	SELECT
	SUM(Amount) AS amount
	FROM funds AS f
)
SELECT
'XBZJFEED' AS [System ID],	
'' AS [Col B],
'' AS [Col C],
f.FAIndexCode AS [INDEX],
'' AS [Col E],
'' AS [Col F],
'59352' AS Account,
'' AS [Col H],
'4000FN' AS [Col I],
F.Amount AS Amount,
'C' AS [Db Cr],
'Add Description' AS [DESCRIPTION]
FROM Funds AS f

UNION

SELECT
'XBZJFEED' AS [System ID],	
'' AS [Col B],
'' AS [Col C],
'422000' AS [INDEX],
'' AS [Col E],
'' AS [Col F],
'59352' AS Account,
'' AS [Col H],
'4000FN' AS [Col I],
t.Amount AS Amount,
'D' AS [Db Cr],
'Add Description' AS [DESCRIPTION]

FROM totalTally AS t</CommandText>
      </Query>
      <Fields>
        <Field Name="System_ID">
          <DataField>System ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_B">
          <DataField>Col B</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_C">
          <DataField>Col C</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="INDEX">
          <DataField>INDEX</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_E">
          <DataField>Col E</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_F">
          <DataField>Col F</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Account">
          <DataField>Account</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_H">
          <DataField>Col H</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Col_I">
          <DataField>Col I</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Amount">
          <DataField>Amount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Db_Cr">
          <DataField>Db Cr</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DESCRIPTION">
          <DataField>DESCRIPTION</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportSections>
    <ReportSection>
      <Body>
        <ReportItems>
          <Tablix Name="Recon_tablix">
            <TablixBody>
              <TablixColumns>
                <TablixColumn>
