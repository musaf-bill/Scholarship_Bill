        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Applcnt_Award">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <CommandText>/*
Purpose:		Applicant Award Details
*/
SELECT
  ISNULL(gid.CON_ID,'n/a') AS CON_ID
, aa.Student_Sort_name
, aa.GID  
, aa.FAS_Code_Name
, aa.Scholarship_Name
, ISNULL(f.FE_ProjectID,'NO MATCH') AS FE_FUND
, aa.Fall_accepted
, aa.Fall_pd
, aa.Spring_accepted
, aa.Spring_pd
, aa.Summer_accepted
, aa.Summer_Pd
, aa.Total_Pd
FROM msuf.SB_APPLICANT_AWARD AS aa
	LEFT JOIN [msuf].[MSU_GID_VIEW] AS gid
		ON gid.MSU_GID = aa.GID
	LEFT JOIN dw.FUND AS f
		ON f.FE_MSU_FAS = aa.FAS_Code_Name
WHERE aa.Rec_type = 'AWARDS' 
--AND f.FE_ProjectID IS null
GROUP BY 
 ISNULL(gid.CON_ID,'n/a') 
, aa.Student_Sort_name
, aa.GID  
, aa.FAS_Code_Name
, aa.Scholarship_Name
, ISNULL(f.FE_ProjectID,'NO MATCH') 
, aa.Fall_accepted
, aa.Fall_pd
, aa.Spring_accepted
, aa.Spring_pd
, aa.Summer_accepted
, aa.Summer_Pd
, aa.Total_Pd
ORDER BY aa.FAS_Code_Name</CommandText>
      </Query>
      <Fields>
        <Field Name="CON_ID">
          <DataField>CON_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Student_Sort_name">
          <DataField>Student_Sort_name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="GID">
          <DataField>GID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FAS_Code_Name">
          <DataField>FAS_Code_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Scholarship_Name">
          <DataField>Scholarship_Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FE_FUND">
          <DataField>FE_FUND</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Fall_accepted">
          <DataField>Fall_accepted</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="Fall_pd">
          <DataField>Fall_pd</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="Spring_accepted">
          <DataField>Spring_accepted</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="Spring_pd">
          <DataField>Spring_pd</DataField>
