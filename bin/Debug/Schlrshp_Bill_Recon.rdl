    <DataSet Name="Fund_Bal">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <CommandText>/*
PURPOSE:		Fund Balance Report
*/
SELECT
*
FROM msuf.SB_FUND_SUMMARY AS fs
WHERE fs.FUND_ID LIKE '9%'
	AND fs.FUND_ID NOT IN ( '91002','91016','91020')</CommandText>
      </Query>
      <Fields>
        <Field Name="FUND_ID">
          <DataField>FUND_ID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
