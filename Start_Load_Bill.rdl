  <DataSets>
    <DataSet Name="Load_Control">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@bill_load_user">
            <Value>=Parameters!bill_load_user.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@bill_source_file_name">
            <Value>=Parameters!bill_source_file_name.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@bill_source_path">
            <Value>=Parameters!bill_source_path.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>
--declare 
--	@bill_source_file_name varchar(50),
--	@bill_source_path varchar(200),
--	@bill_load_user varchar(20)

select
	@bill_load_user as 'Schlr_Bill_Load_User',
	@bill_source_file_name as 'Schlr_Bill_Source_File',
	@bill_source_path as 'Schlr_Bill_Source_Path',
	--@award_source_path + '/' + @award_source_file_name as 'Award_Src_Full_Path',
	convert(varchar, getdate(), 120) as 'Schlr_Bill_load_date'
;
update MSUF.CNTL_INFO
	set CNTL_INFO =isnull(@bill_load_user, '')
	where CNTL_KEY = 'Schlr_Bill_Load_User'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = isnull(@bill_source_file_name, '')
	where CNTL_KEY = 'Schlr_Bill_Source_File'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = isnull(@bill_source_path, '')
	where CNTL_KEY = 'Schlr_Bill_Source_Path'
;
update MSUF.CNTL_INFO
	set CNTL_INFO = convert(varchar, getdate(), 120) 
	where CNTL_KEY = 'Schlr_Bill_Load_Date'
;</CommandText>
      </Query>
      <Fields>
        <Field Name="Schlr_Bill_Load_User">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Schlr_Bill_Load_User</DataField>
        </Field>
        <Field Name="Schlr_Bill_Source_File">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Schlr_Bill_Source_File</DataField>
        </Field>
        <Field Name="Schlr_Bill_Source_Path">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Schlr_Bill_Source_Path</DataField>
        </Field>
        <Field Name="Schlr_Bill_load_date">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Schlr_Bill_load_date</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EXEC_UserName">
      <Query>
        <DataSourceName>MSDB</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@job_name">
            <Value>=Parameters!job_name.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>waitfor delay '00:00:10';

EXEC msdb.dbo.sp_start_job 'RunSSIS_LoadBill';

waitfor delay '00:00:30';

EXEC msdb.dbo.sp_help_jobactivity @job_name = 'RunSSIS_LoadBill';</CommandText>
      </Query>
      <Fields>
        <Field Name="session_id">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>session_id</DataField>
        </Field>
