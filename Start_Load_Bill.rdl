    <DataSet Name="LastLoaded">
      <Query>
        <DataSourceName>SQLPROD</DataSourceName>
        <CommandText>	SELECT
    (SELECT CNTL_INFO FROM MSUF.CNTL_INFO WHERE CNTL_KEY = 'Schlr_Bill_Load_Date') 
	+ ' - ' 
	+ (SELECT CNTL_INFO FROM MSUF.CNTL_INFO WHERE CNTL_KEY = 'Schlr_Bill_Source_File') AS LastLoaded;</CommandText>
      </Query>
      <Fields>
        <Field Name="LastLoaded">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>LastLoaded</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
